# Render Environment Variables
# Copy this file to .env and fill in the values (not needed for demo mode)

# Database (optional - demo mode uses JSON file)
# DB_HOST=localhost
# DB_NAME=umuganda_t
# DB_USER=root
# DB_PASSWORD=yourpassword

# JWT Secret (auto-generated in demo mode)
#JWT_SECRET=your-jwt-secret-key

# Server Port (Render assigns this automatically)
# PORT=10000

# OpenAI API Key (optional - for translation features)
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_TRANSLATION_MODEL=gpt-5.4-mini

